# Banking System Makefile

CC = gcc
CFLAGS = -Wall -Wextra -std=c99 -g
LDFLAGS = -lm

# Main executable name
TARGET = banking_system

# Source files
SOURCES = main_banking.c accounts.c auth.c transactions.c utils.c \
          wallet.c loans.c fixed_deposit.c fraud.c queue.c admin.c

# Object files
OBJECTS = $(SOURCES:.c=.o)

# Header files
HEADERS = banking_system.h accounts.h auth.h transactions.h utils.h \
          wallet.h loans.h fixed_deposit.h fraud.h queue.h admin.h

# Default target
all: $(TARGET)

# Build the executable
$(TARGET): $(OBJECTS)
	@echo "Linking $(TARGET)..."
	$(CC) $(CFLAGS) -o $(TARGET) $(OBJECTS) $(LDFLAGS)
	@echo "Build successful! Run with: ./$(TARGET)"

# Compile source files to object files
%.o: %.c $(HEADERS)
	@echo "Compiling $<..."
	$(CC) $(CFLAGS) -c $< -o $@

# Clean build artifacts
clean:
	@echo "Cleaning build artifacts..."
	rm -f $(OBJECTS) $(TARGET)
	@echo "Clean complete!"

# Clean everything including generated files
distclean: clean
	@echo "Removing data files..."
	rm -f *.dat
	@echo "Distclean complete!"

# Run the program
run: $(TARGET)
	./$(TARGET)

# Help target
help:
	@echo "Banking System - Build Instructions"
	@echo "===================================="
	@echo "make           - Build the banking system"
	@echo "make run       - Build and run"
	@echo "make clean     - Remove build artifacts"
	@echo "make distclean - Remove all generated files"
	@echo "make help      - Show this help message"

.PHONY: all run clean distclean help
